# ── Database ──────────────────────────────────────────────────────────────────
# TimescaleDB (PostgreSQL) async connection string
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/moodmap

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co

# ── Celery / Redis ────────────────────────────────────────────────────────────
REDIS_PASSWORD=choose_a_strong_random_password_here
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
CLOUDFLARE_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY_ID=your_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_secret_access_key
CLOUDFLARE_R2_BUCKET_NAME=moodmap-audio

# ── AI / ML ───────────────────────────────────────────────────────────────────
HF_TOKEN=hf_your_huggingface_token
ANTHROPIC_API_KEY=sk-ant-api03-your_key

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_key

# ── CORS (comma-separated list of allowed origins) ───────────────────────────
CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000
