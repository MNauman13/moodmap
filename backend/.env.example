# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (TimescaleDB) async connection string.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/moodmap

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
# Service-role key — bypasses Row Level Security. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Redis / Celery ────────────────────────────────────────────────────────────
# Local dev (no auth):
REDIS_PASSWORD=choose_a_strong_random_password_here
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# Production Docker (password enforced, hostname = service name):
# CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
# CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
CLOUDFLARE_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY_ID=your_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_secret_access_key
CLOUDFLARE_R2_BUCKET_NAME=moodmap-audio

# ── AI / ML ───────────────────────────────────────────────────────────────────
HF_TOKEN=hf_your_huggingface_token
ANTHROPIC_API_KEY=sk-ant-api03-your_key

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_key
# Must be a domain you own and have verified in the Resend dashboard.
# @gmail.com and other free domains cannot be used as Resend senders.
RESEND_FROM_EMAIL=MoodMap <noreply@yourdomain.com>

# ── CORS / Frontend ───────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000
# Full public URL of the frontend — used in email links.
FRONTEND_URL=https://your-frontend.vercel.app

# ── Field-level encryption ────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: Never change this after data has been written — all encrypted rows
# (journal entries, nudge content) will become permanently unreadable.
FIELD_ENCRYPTION_KEY=your-generated-fernet-key-here

# ── Optional ──────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO
# Environment label shown in Sentry and logs.
ENVIRONMENT=production
# Sentry DSN for error tracking. Leave blank to disable.
# SENTRY_DSN=https://your-key@sentry.io/project-id
